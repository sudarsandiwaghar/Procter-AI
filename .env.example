# Database configuration (MySQL via PyMySQL driver)
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/proctorai

# JWT security settings
JWT_SECRET_KEY=your_super_secret_jwt_signing_key_must_be_long_and_random_64_chars_recommended
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Integration
GEMINI_API_KEY=your_google_gemini_api_key_here

# App settings
APP_NAME=ProctorAI-Backend
DEBUG=True
PORT=8000
HOST=0.0.0.0
